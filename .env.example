# Environment Configuration
NODE_ENV=development

# Database Configuration (Supabase)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Server Configuration
PORT=3001
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://customer.idswyft.app,https://idswyft.app,https://www.idswyft.app

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
API_KEY_SECRET=your-api-key-encryption-secret
ENCRYPTION_KEY=your-32-character-encryption-key
SERVICE_TOKEN=                          # min 64 hex chars — shared secret between backend and vaas-backend
RAILWAY_ALLOWED_ORIGINS=               # comma-separated origins on Railway (optional)

# File Storage
STORAGE_PROVIDER=supabase
# Alternative: local, s3
SUPABASE_STORAGE_BUCKET=identity-documents
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=idswyft-documents

# OCR and Computer Vision
TESSERACT_PATH=/usr/bin/tesseract
OPENCV_MODELS_PATH=./models

# VaaS Backend (Verification-as-a-Service multi-tenant layer)
VAAS_SUPABASE_URL=https://yourvaasproject.supabase.co
VAAS_SUPABASE_ANON_KEY=
VAAS_SUPABASE_SERVICE_ROLE_KEY=
VAAS_JWT_SECRET=                        # min 32 chars — separate from core JWT_SECRET
VAAS_API_KEY_SECRET=                    # min 32 chars
VAAS_SUPER_ADMIN_EMAILS=admin@yourdomain.com
MAILGUN_API_KEY=                        # enables email invitations to tenants
MAILGUN_DOMAIN=mail.yourdomain.com

# Optional Paid API Services
PERSONA_API_KEY=your_persona_api_key
PERSONA_TEMPLATE_ID=your_persona_template_id
ONFIDO_API_KEY=your_onfido_api_key
ONFIDO_WEBHOOK_TOKEN=your_onfido_webhook_token

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS_PER_USER=5
RATE_LIMIT_MAX_REQUESTS_PER_DEV=1000

# Webhook Configuration
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_TIMEOUT_MS=5000

# Compliance
DATA_RETENTION_DAYS=90
GDPR_COMPLIANCE=true

# Development/Sandbox
SANDBOX_MODE=true
ENABLE_MOCK_VERIFICATION=true
MOCK_VERIFICATION_DELAY_MS=2000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json